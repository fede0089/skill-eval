{
  "name": "@fede0089/skill-eval",
  "version": "1.0.1",
  "description": "CLI to evaluate agent skills triggering",
  "main": "dist/index.js",
  "bin": {
    "skill-eval": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags",
    "prepare": "npm run build",
    "build": "tsc",
    "start": "node dist/index.js",
    "test:trigger": "npm run build && node ./dist/index.js trigger --workspace . --skill ./mock-skill --debug",
    "test:functional": "npm run build && node ./dist/index.js functional --workspace . --skill ./mock-skill --debug",
    "test:unit": "tsx --test \"tests/**/*.test.ts\""
  },
  "type": "module",
  "keywords": [
    "skill",
    "eval",
    "agent",
    "llm",
    "gemini"
  ],
  "author": "Federico Mete",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fede0089/skill-eval.git"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "listr2": "^10.2.1",
    "ora": "^5.4.1",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
