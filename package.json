{
  "name": "skill-eval",
  "version": "1.0.0",
  "description": "CLI to evaluate agent skills triggering",
  "main": "dist/index.js",
  "bin": {
    "skill-eval": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test:trigger": "npm run build && node ./dist/index.js trigger --skill ./mock-skill",
    "test:functional": "npm run build && node ./dist/index.js functional --skill ./mock-skill",
    "test:unit": "tsx --test tests/**/*.test.ts",
    "test": "npm run test:unit && npm run test:trigger && npm run test:functional"
  },
  "keywords": [
    "skill",
    "eval",
    "agent",
    "llm",
    "gemini"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
