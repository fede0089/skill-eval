{
  "name": "skill-eval",
  "version": "1.0.0",
  "description": "CLI to evaluate agent skills triggering",
  "main": "dist/index.js",
  "bin": {
    "skill-eval": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test:trigger": "npm run build && node ./dist/index.js trigger --skill ./mock-skill",
    "test:functional": "npm run build && node ./dist/index.js functional --skill ./mock-skill",
    "test:unit": "tsx --test \"tests/**/*.test.ts\""
  },
  "type": "module",
  "keywords": [
    "skill",
    "eval",
    "agent",
    "llm",
    "gemini"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "listr2": "^10.2.1",
    "ora": "^5.4.1",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
